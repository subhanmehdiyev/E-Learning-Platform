@page
@using E_Learning_Platform.Models
@model E_Learning_Platform.Pages.Courses.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>List of All Courses</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Course[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Course[0].Author)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Course[0].ReleaseDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Course[0].Category)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Course[0].Description)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Course)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Author)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ReleaseDate)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Category)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Description)
                </td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" role="button">Edit</a> 
                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" role="button">Delete</a> 
                    <a asp-page-handler="SendCourseName" asp-route-name="@item.Name" class="btn btn-outline-success">Results</a> 
                    <a asp-page="/GettingResponse" asp-route-id="@item.Id" class="btn btn-outline-secondary" role="button">Responses</a>
                </td>
            </tr>
        }
    </tbody>
</table>