@page
@model E_Learning_Platform.Pages.Courses.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Are you sure you want to delete this course and its materials ?</h1>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2 mb-2">
            @Html.DisplayNameFor(model => model.Course.Name)
        </dt>
        <dd class="col-sm-10 mb-2">
            @Html.DisplayFor(model => model.Course.Name)
        </dd>
        <dt class="col-sm-2 mb-2">
            @Html.DisplayNameFor(model => model.Course.Author)
        </dt>
        <dd class="col-sm-10 mb-2">
            @Html.DisplayFor(model => model.Course.Author)
        </dd>
        <dt class="col-sm-2 mb-2">
            @Html.DisplayNameFor(model => model.Course.AuthorEmail)
        </dt>
        <dd class="col-sm-10 mb-2">
            @Html.DisplayFor(model => model.Course.AuthorEmail)
        </dd>
        <dt class="col-sm-2 mb-2">
            @Html.DisplayNameFor(model => model.Course.ReleaseDate)
        </dt>
        <dd class="col-sm-10 mb-2">
            @Html.DisplayFor(model => model.Course.ReleaseDate)
        </dd>
        <dt class="col-sm-2 mb-2">
            @Html.DisplayNameFor(model => model.Course.Category)
        </dt>
        <dd class="col-sm-10 mb-2">
            @Html.DisplayFor(model => model.Course.Category)
        </dd>
        <dt class="col-sm-2 mb-2">
            @Html.DisplayNameFor(model => model.Course.Description)
        </dt>
        <dd class="col-sm-10 mb-2">
            @Html.DisplayFor(model => model.Course.Description)
        </dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="Course.Id" />
        <input type="submit" value="Delete" class="btn btn-outline-danger" /> |
        <a asp-page="./Index" class="btn btn-outline-secondary" role="button">Back to List</a>
    </form>
</div>
