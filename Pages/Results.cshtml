@page
@model E_Learning_Platform.Pages.ResultsModel

@{
    ViewData["Title"] = "Results";

    var binLabels = Model.CourseResults.Select(result=> result.CourseName).ToArray();
    var quiz1Bins = Model.CourseResults.Select(result => result.Quiz1Result).ToArray();
    var midtermBins = Model.CourseResults.Select(result => result.MidtermResult).ToArray();
    var quiz2Bins = Model.CourseResults.Select(result => result.Quiz2Result).ToArray();
    var finalBins = Model.CourseResults.Select(result => result.FinalResult).ToArray();
}

<h1>Results</h1>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.CourseResults[0].CourseName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CourseResults[0].Quiz1Result)  /10
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CourseResults[0].MidtermResult)  /25
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CourseResults[0].Quiz2Result)  /15
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CourseResults[0].FinalResult)  /50
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CourseResults[0].Total)  /100
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.CourseResults)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.CourseName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Quiz1Result)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.MidtermResult)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Quiz2Result)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.FinalResult)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Total)
                </td>
            </tr>
        }
    </tbody>
</table>

<canvas id="histogramChart" width="800" height="500" style="margin-top:100px"></canvas>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const binLabels = @Html.Raw(Json.Serialize(binLabels));
    const quiz1Data = @Html.Raw(Json.Serialize(quiz1Bins));
    const midtermData = @Html.Raw(Json.Serialize(midtermBins));
    const quiz2Data = @Html.Raw(Json.Serialize(quiz2Bins));
    const finalData = @Html.Raw(Json.Serialize(finalBins));

    const ctx = document.getElementById('histogramChart').getContext('2d');
    const histogramChart = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: binLabels,
            datasets: [
                {
                    label: 'Quiz 1',
                    data: quiz1Data,
                    backgroundColor: 'rgba(255, 99, 132, 0.7)'
                },
                {
                    label: 'Midterm Exam',
                    data: midtermData,
                    backgroundColor: 'rgba(54, 162, 235, 0.7)'
                },
                {
                    label: 'Quiz 2',
                    data: quiz2Data,
                    backgroundColor: 'rgba(255, 206, 86, 0.7)'
                },
                {
                    label: 'Final Exam',
                    data: finalData,
                    backgroundColor: 'rgba(54, 206, 127, 0.7)'
                }]
        },
        options: {
            responsive: true,
            plugins: {
                tooltip: { mode: 'index', intersect: false },
                legend: { position: 'top' }
            },
            scales: {
                x: {
                    stacked: true,
                    title: {
                        display: true,
                        text: 'Courses'
                    }
                },
                y: {
                    stacked: true,
                    beginAtZero: true,
                    title: {
                        display: true,
                        text: 'Scores'
                    }
                }
            }
        }
    });
</script>
