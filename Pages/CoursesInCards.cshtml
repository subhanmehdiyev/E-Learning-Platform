@page
@model E_Learning_Platform.Pages.CoursesInCardsModel

@{
    ViewData["Title"] = "CoursesInCards";
}

<div class="container d-flex flex-row flex-wrap mt-4 justify-content-center">
    @foreach (var item in Model.Course)
    {
        <div class="card me-4 mb-4" style="width: 18rem;">
            <img src="/images/CourseImage.jpg" class="card-img-top">
            <div class="card-body">
                <h5 class="card-title">@Html.DisplayFor(modelItem => item.Name)</h5>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item">@Html.DisplayNameFor(modelItem => item.Author): @Html.DisplayFor(modelItem => item.Author)</li>
                <li class="list-group-item">@Html.DisplayNameFor(modelItem => item.Category): @Html.DisplayFor(modelItem => item.Category)</li>
            </ul>
            <div class="card-body">
                <a asp-page="/BeginedCourse" asp-route-id="@item.Id" class="btn btn-outline-success" role="button">
                    Begin
                </a>
            </div>
        </div>
    }
</div>