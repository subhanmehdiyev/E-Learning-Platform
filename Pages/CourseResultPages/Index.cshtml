@page
@model E_Learning_Platform.Pages.CourseResultPages.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Course Results</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.CourseResults[0].StudentEmail)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CourseResults[0].Quiz1Result)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CourseResults[0].MidtermResult)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CourseResults[0].Quiz2Result)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CourseResults[0].FinalResult)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CourseResults[0].Total)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.CourseResults) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.StudentEmail)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Quiz1Result)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MidtermResult)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Quiz2Result)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FinalResult)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Total)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-primary" role="button">Edit</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" role="button">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
