@page
@model E_Learning_Platform.Pages.CourseMaterialsModel
@{
    ViewData["Title"] = "CourseMaterials";
}

<h1>Enter Course Materials</h1>

<hr />
<div class="row">
    <div class="col-md-6 mb-3">
        <form method="post" enctype="multipart/form-data">
            <div class="form-group mb-3">
                <label class="form-label mb-2">Read Material</label>
                <input class="form-control" type="file" name="CourseMaterials.ReadMaterial">
            </div>
            <div class="form-group mb-3">
                <label class="form-label mb-2">Midterm Exam</label>
                <input class="form-control" type="file" name="CourseMaterials.MidtermExam">
            </div>
            <div class="form-group mb-3">
                <label class="form-label mb-2">Quiz 1</label>
                <input class="form-control" type="file" name="CourseMaterials.Quiz1">
            </div>
            <div class="form-group mb-3">
                <label class="form-label mb-2">Quiz 2</label>
                <input class="form-control" type="file" name="CourseMaterials.Quiz2">
            </div>
            <div class="form-group mb-3">
                <label class="form-label mb-2">Final Exam</label>
                <input class="form-control" type="file" name="CourseMaterials.FinalExam">
            </div>
            <div class="form-group mb-3" method="post">
                <input type="submit" value="Create" class="btn btn-outline-primary" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}